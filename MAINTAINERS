# MAINTAINERS
#
# This file maps monorepo sections to their owning teams and individuals.
# Format used by Phoenix Security monorepo import to split sections into
# separate workspace repo rows for independent scanning and policy application.
#
# Format:
#   [section]
#   path      = <relative path from repo root>
#   team      = <team slug>
#   lead      = <github username>
#   email     = <team contact email>
#   language  = <primary language>
#   tier      = <criticality: critical | high | medium | low>
#   scan_policy = <phoenix policy id or name>

